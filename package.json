{
  "name": "skovlund.dev",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:network": "astro dev --host",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:network": "astro preview --host",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "playwright test",
    "test:a11y": "playwright test --grep-invert contrast",
    "test:contrast": "playwright test --grep contrast"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@lucide/astro": "^0.577.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^5.18.0",
    "astro-icon": "^1.1.5",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "photoswipe": "^5.4.4",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "smplr": "^0.19.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@iconify-json/simple-icons": "^1.2.74",
    "@playwright/test": "^1.58.2",
    "@types/canvas-confetti": "^1.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.57.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "minimatch": ">=10.2.1",
      "lodash": ">=4.17.23"
    }
  }
}
