---
import Container from "@components/Container.astro";
import Typewriter from "@components/Typewriter.astro";
import { SITE, SOCIALS } from "@consts";
import { site, footer, footerMessages, paletteColorCount } from "@i18n/en";
import { Icon } from "astro-icon/components";
import { Code, Mail, Rss } from "@lucide/astro";

// Commit SHA display
const COMMIT_SHA_LENGTH: number = 7;
const commitSha: string = import.meta.env.COMMIT_SHA || "";
const sourceUrl: string = commitSha
  ? `${site.sourceUrl}/commit/${commitSha}`
  : site.sourceUrl;
const sourceLabel: string = commitSha
  ? commitSha.slice(0, COMMIT_SHA_LENGTH)
  : footer.sourceLabel;

// Brand colors for non-social links
const EMAIL_COLOR: string = "#D4A017";
const RSS_COLOR: string = "#F26522";

// Typewriter timing constants for footer messages
const FOOTER_TYPEWRITER_TYPE_SPEED_MS: number = 40;
const FOOTER_TYPEWRITER_DELETE_SPEED_MS: number = 25;
const FOOTER_TYPEWRITER_PAUSE_BEFORE_DELETE_MS: number = 4300;
const FOOTER_TYPEWRITER_PAUSE_AFTER_DELETE_MS: number = 200;
---

<footer class="animate">
  <Container>
    <div class="flex flex-col gap-3">
      <ul id="socials" class="flex flex-wrap justify-center gap-1.5 font-mono">
        {
          SOCIALS.map((social) => (
            <li>
              <a
                href={social.HREF}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${SITE.NAME} on ${social.NAME}`}
                class="group flex items-center gap-1 px-2 py-1.5 rounded-lg border border-light-surface/40 dark:border-dark-surface/40 hover:border-light-surface dark:hover:border-dark-surface hover:bg-light-surface/30 dark:hover:bg-dark-surface/30 text-xs transition-all duration-300"
              >
                <Icon
                  name={social.ICON}
                  size={14}
                  class="fill-current opacity-60 group-hover:opacity-100 transition-all duration-300"
                  style={`color: ${social.COLOR}`}
                  aria-hidden="true"
                />
                {social.NAME}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={`mailto:${SITE.EMAIL}`}
            aria-label={`Email ${SITE.NAME}`}
            class="group flex items-center gap-1 px-2 py-1.5 rounded-lg border border-light-surface/40 dark:border-dark-surface/40 hover:border-light-surface dark:hover:border-dark-surface hover:bg-light-surface/30 dark:hover:bg-dark-surface/30 text-xs font-mono transition-all duration-300"
          >
            <Mail
              size={14}
              class="opacity-60 group-hover:opacity-100 transition-all duration-300"
              style={`color: ${EMAIL_COLOR}`}
            />
            Email
          </a>
        </li>
        <li>
          <a
            href="/rss.xml"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="RSS feed"
            class="group flex items-center gap-1 px-2 py-1.5 rounded-lg border border-light-surface/40 dark:border-dark-surface/40 hover:border-light-surface dark:hover:border-dark-surface hover:bg-light-surface/30 dark:hover:bg-dark-surface/30 text-xs font-mono transition-all duration-300"
          >
            <Rss
              size={14}
              class="opacity-60 group-hover:opacity-100 transition-all duration-300"
              style={`color: ${RSS_COLOR}`}
            />
            RSS
          </a>
        </li>
      </ul>
      <hr class="border-light-surface/40 dark:border-dark-surface/40" />
      <div class="flex justify-between items-center">
        <div
          class="flex gap-1.5 items-center text-light-fg-muted dark:text-dark-fg-muted"
        >
          &copy; <span id="footer-year">{new Date().getFullYear()}</span>
          {SITE.NAME}
        </div>
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-sm opacity-60 hover:opacity-100 hover:text-light-accent dark:hover:text-dark-accent transition-all duration-300"
        >
          <Code size={14} />
          {sourceLabel}
        </a>
      </div>
      <hr class="border-light-surface/40 dark:border-dark-surface/40" />
      <div
        class="text-xs italic text-center sm:whitespace-nowrap sm:overflow-visible"
      >
        <Typewriter
          id="footer-message"
          texts={footerMessages}
          mode="shuffle"
          paletteColorCount={paletteColorCount}
          typeSpeedMs={FOOTER_TYPEWRITER_TYPE_SPEED_MS}
          deleteSpeedMs={FOOTER_TYPEWRITER_DELETE_SPEED_MS}
          pauseBeforeDeleteMs={FOOTER_TYPEWRITER_PAUSE_BEFORE_DELETE_MS}
          pauseAfterDeleteMs={FOOTER_TYPEWRITER_PAUSE_AFTER_DELETE_MS}
        />
      </div>
    </div>
  </Container>
</footer>
