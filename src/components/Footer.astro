---
import { Icon } from "astro-icon/components";

import Container from "@components/Container.astro";
import Typewriter from "@components/Typewriter.astro";
import { SITE, SOCIALS } from "@consts";
import {
  aria,
  footer,
  footerMessages,
  paletteColorCount,
  site,
} from "@i18n/en";
import { Code, Mail, Rss } from "@lucide/astro";

// Commit SHA display
const COMMIT_SHA_LENGTH: number = 7;
const commitSha: string = import.meta.env.COMMIT_SHA || "";
const sourceUrl: string = commitSha
  ? `${site.sourceUrl}/commit/${commitSha}`
  : site.sourceUrl;
const sourceLabel: string = commitSha
  ? commitSha.slice(0, COMMIT_SHA_LENGTH)
  : footer.sourceLabel;

// Brand colors for non-social links
const EMAIL_COLOR: string = "#D4A017";
const RSS_COLOR: string = "#F26522";

// Shared tooltip class for hover labels on social/utility icons
const TOOLTIP_CLASS: string =
  "hidden sm:block absolute top-full mt-5 -translate-y-1/2 text-xs font-mono text-light-fg-muted dark:text-dark-fg-muted opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap pointer-events-none bg-light-bg dark:bg-dark-bg px-1";

// Typewriter timing constants for footer messages
const FOOTER_TYPEWRITER_TYPE_SPEED_MS: number = 40;
const FOOTER_TYPEWRITER_DELETE_SPEED_MS: number = 120;
const FOOTER_TYPEWRITER_PAUSE_BEFORE_DELETE_MS: number = 4300;
const FOOTER_TYPEWRITER_PAUSE_AFTER_DELETE_MS: number = 200;
---

<footer class="animate">
  <Container>
    <div class="flex flex-col gap-5">
      <div id="socials" class="flex items-center justify-between font-mono">
        <ul class="flex flex-wrap gap-3">
          {
            SOCIALS.map((social) => (
              <li>
                <a
                  href={social.HREF}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.NAME}
                  class="group relative flex items-center justify-center"
                >
                  <Icon
                    name={social.ICON}
                    size={20}
                    class="fill-current opacity-50 group-hover:opacity-100 transition-all duration-300"
                    style={`color: ${social.COLOR}`}
                    aria-hidden="true"
                  />
                  <span class={TOOLTIP_CLASS}>{social.NAME}</span>
                </a>
              </li>
            ))
          }
        </ul>
        <ul class="flex gap-3">
          <li>
            <a
              href={`mailto:${SITE.EMAIL}`}
              aria-label={footer.emailLabel}
              class="group relative flex items-center justify-center"
            >
              <Mail
                size={20}
                class="opacity-50 group-hover:opacity-100 transition-all duration-300"
                style={`color: ${EMAIL_COLOR}`}
                aria-hidden="true"
              />
              <span class={TOOLTIP_CLASS}>
                {footer.emailLabel}
              </span>
            </a>
          </li>
          <li>
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={aria.rssFeed}
              class="group relative flex items-center justify-center"
            >
              <Rss
                size={20}
                class="opacity-50 group-hover:opacity-100 transition-all duration-300"
                style={`color: ${RSS_COLOR}`}
                aria-hidden="true"
              />
              <span class={TOOLTIP_CLASS}>
                {footer.rssLabel}
              </span>
            </a>
          </li>
        </ul>
      </div>
      <hr class="border-light-surface/40 dark:border-dark-surface/40" />
      <div class="flex justify-between items-center">
        <div
          class="flex gap-1.5 items-center text-light-fg-muted dark:text-dark-fg-muted"
        >
          &copy; <span id="footer-year">{new Date().getFullYear()}</span>
          {SITE.NAME}
        </div>
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={sourceLabel}
          class="flex items-center gap-1.5 text-sm opacity-60 hover:opacity-100 hover:text-light-accent dark:hover:text-dark-accent transition-all duration-300"
        >
          <Code size={14} aria-hidden="true" />
          {sourceLabel}
        </a>
      </div>
      <hr class="border-light-surface/40 dark:border-dark-surface/40" />
      <div
        class="text-xs italic text-center sm:whitespace-nowrap sm:overflow-visible"
      >
        <Typewriter
          id="footer-message"
          texts={footerMessages}
          mode="shuffle"
          colorCount={paletteColorCount}
          deleteMode="word"
          typeSpeedMs={FOOTER_TYPEWRITER_TYPE_SPEED_MS}
          deleteSpeedMs={FOOTER_TYPEWRITER_DELETE_SPEED_MS}
          pauseBeforeDeleteMs={FOOTER_TYPEWRITER_PAUSE_BEFORE_DELETE_MS}
          pauseAfterDeleteMs={FOOTER_TYPEWRITER_PAUSE_AFTER_DELETE_MS}
        />
      </div>
    </div>
  </Container>
</footer>
