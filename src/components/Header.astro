---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import ThemePicker from "@components/ThemePicker.astro";
import { nav, settings, site } from "@i18n/en";
import { Menu, Settings, X } from "@lucide/astro";
---

<header>
  <Container>
    <div class="flex justify-between items-center font-mono">
      <a
        href="/"
        id="nav-home"
        class="font-semibold text-light-accent dark:text-dark-accent hover:text-light-accent-hover dark:hover:text-dark-accent-hover transition-colors duration-300"
      >
        {site.brandName}
      </a>

      <!-- Desktop nav + settings -->
      <div class="hidden sm:flex items-center gap-3">
        <nav class="flex gap-1.5 text-base">
          <Link href="/about" underline={false}>{nav.about}</Link>
          <span class="text-light-fg-muted/30 dark:text-dark-fg-muted/30"
            >/</span
          >
          <Link href="/blog" underline={false}>{nav.blog}</Link>
          <span class="text-light-fg-muted/30 dark:text-dark-fg-muted/30"
            >/</span
          >
          <Link href="/projects" underline={false}>{nav.projects}</Link>
          <span class="text-light-fg-muted/30 dark:text-dark-fg-muted/30"
            >/</span
          >
          <Link href="/shelf" underline={false}>{nav.shelf}</Link>
        </nav>
        <div
          class="flex items-center ml-1 border-l border-light-surface dark:border-dark-surface pl-3"
        >
          <div class="relative" data-settings-root>
            <button
              data-settings-trigger
              aria-label={settings.trigger}
              aria-expanded="false"
              class="group size-7 flex items-center justify-center rounded-full hover:bg-light-surface/50 dark:hover:bg-dark-surface/50 transition-colors duration-300"
            >
              <Settings
                size={15}
                class="stroke-current group-hover:stroke-light-fg group-hover:dark:stroke-dark-fg transition-colors duration-300"
              />
            </button>

            <div
              data-settings-panel
              class="settings-panel hidden absolute right-0 top-full mt-2 w-72 p-3 bg-light-bg-alt dark:bg-dark-bg-alt border border-light-surface dark:border-dark-surface rounded-lg shadow-lg z-50 font-mono"
            >
              <ThemePicker />
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="sm:hidden size-9 flex items-center justify-center rounded-full hover:bg-light-surface/50 dark:hover:bg-dark-surface/50 transition-colors duration-300"
        aria-label={nav.toggleMenu}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu
          size={20}
          id="menu-open-icon"
          class="stroke-current"
          aria-hidden="true"
        />
        <X
          size={20}
          id="menu-close-icon"
          class="stroke-current hidden"
          aria-hidden="true"
        />
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden pt-4 pb-2 font-mono">
      <nav class="flex flex-col gap-3 text-base">
        <Link href="/about" underline={false}>{nav.about}</Link>
        <Link href="/blog" underline={false}>{nav.blog}</Link>
        <Link href="/projects" underline={false}>{nav.projects}</Link>
        <Link href="/shelf" underline={false}>{nav.shelf}</Link>
      </nav>

      <div
        class="mt-4 pt-3 border-t border-light-surface/30 dark:border-dark-surface/30"
      >
        <ThemePicker variant="touch" />
      </div>
    </div>
  </Container>
</header>
