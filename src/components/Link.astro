---
import { classNames } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
};

const { href, external, underline = true, ...rest } = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : "_self"}
  rel={external ? "noopener noreferrer" : undefined}
  class={classNames(
    "inline text-light-accent dark:text-dark-accent hover:text-light-accent-hover hover:dark:text-dark-accent-hover transition-colors duration-300 ease-in-out",
    underline &&
      "underline underline-offset-2 decoration-light-accent/30 dark:decoration-dark-accent/30 hover:decoration-light-accent/60 hover:dark:decoration-dark-accent/60",
  )}
  {...rest}
>
  <slot />
</a>
