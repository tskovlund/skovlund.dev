---
import type { CollectionEntry } from "astro:content";
import Link from "@components/Link.astro";
import ProjectIcon from "@components/ProjectIcon.astro";

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;

const hasExternalLinks = entry.data.repoURL || entry.data.demoURL;
const projectUrl = entry.data.featured ? `/projects/${entry.slug}` : undefined;
---

<div
  class:list={[
    "relative flex items-center rounded-lg border border-light-surface dark:border-dark-surface transition-all duration-300 ease-in-out overflow-hidden",
    projectUrl
      ? "hover:border-light-accent/40 dark:hover:border-dark-accent/40"
      : "",
  ]}
>
  <div class="flex items-center justify-center w-18 shrink-0">
    <ProjectIcon
      icon={entry.data.icon}
      iconColor={entry.data.iconColor}
      size={28}
    />
  </div>
  <div class="min-w-0 py-3 pr-4">
    <div class="font-semibold">
      {
        projectUrl ? (
          <a
            href={projectUrl}
            class="stretched-link hover:text-light-accent dark:hover:text-dark-accent transition-colors"
          >
            {entry.data.title}
          </a>
        ) : (
          entry.data.title
        )
      }
    </div>
    <div class="text-sm">{entry.data.description}</div>
    {
      (hasExternalLinks || projectUrl) && (
        <nav class="relative z-10 flex gap-1 mt-1.5 text-sm">
          {entry.data.repoURL && (
            <Link href={entry.data.repoURL} external>
              source
            </Link>
          )}
          {entry.data.repoURL && entry.data.demoURL && <span>/</span>}
          {entry.data.demoURL && (
            <Link href={entry.data.demoURL} external>
              demo
            </Link>
          )}
          {projectUrl && hasExternalLinks && <span>/</span>}
          {projectUrl && <Link href={projectUrl}>read more</Link>}
        </nav>
      )
    }
  </div>
</div>

<style>
  .stretched-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>
