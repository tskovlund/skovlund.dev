---
import type { ThemeColor } from "@types";
import { classNames } from "@lib/utils";
import { THEME_COLOR_CLASSES } from "@lib/icons";

interface Props {
  color: ThemeColor;
  level?: "h2" | "h3" | "h4" | "h5" | "h6";
}

const { color, level: Element = "h2" } = Astro.props;
---

<Element
  class={classNames("font-mono font-semibold", THEME_COLOR_CLASSES[color])}
>
  <slot />
</Element>
