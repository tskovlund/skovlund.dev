---
/**
 * Theme picker — appearance mode (light/dark/system) and color scheme selector.
 *
 * Shared across the header settings panel, mobile menu, and inline project page.
 * Uses `data-theme-button` and `data-scheme-button` attributes so the existing
 * event delegation in main.ts handles all interactions automatically.
 *
 * Variants:
 * - "compact" — header desktop panel (small icons, 2-column scheme grid)
 * - "touch"   — mobile menu (larger tap targets, 2-column scheme grid)
 * - "inline"  — embeddable in content (wrapped in a card, 3-column scheme grid)
 */
import { Sun, Moon, Monitor } from "@lucide/astro";
import { settings, colorSchemes } from "@i18n/en";

interface Props {
  variant?: "compact" | "touch" | "inline";
}

const { variant = "compact" } = Astro.props;

const isTouch = variant === "touch" || variant === "inline";
const iconSize = isTouch ? 14 : 13;
const buttonPaddingY = isTouch ? "py-2" : "py-1.5";
const dotSize = isTouch ? "size-3" : "size-2.5";
const schemeCols = variant === "inline" ? "grid-cols-3" : "grid-cols-2";

const themeButtonClass = `flex-1 flex items-center justify-center gap-1.5 ${buttonPaddingY} rounded-md text-xs hover:bg-light-surface/30 dark:hover:bg-dark-surface/30 transition-colors duration-200`;
const schemeButtonClass = `flex items-center gap-2 px-2 ${buttonPaddingY} rounded-md text-xs hover:bg-light-surface/30 dark:hover:bg-dark-surface/30 transition-colors duration-200 w-full text-left`;
const labelClass =
  "text-xs font-mono uppercase tracking-wider text-light-fg-subtle dark:text-dark-fg-subtle";
---

<div class="flex flex-col gap-3">
  <div class="flex flex-col gap-1.5">
    <span class={labelClass}>{settings.appearance}</span>
    <div class="flex gap-1">
      <button
        data-theme-button="light"
        aria-label={settings.themeLight}
        aria-pressed="false"
        class={themeButtonClass}
      >
        <Sun size={iconSize} class="shrink-0" aria-hidden="true" />
        <span>{settings.themeLight}</span>
      </button>
      <button
        data-theme-button="dark"
        aria-label={settings.themeDark}
        aria-pressed="false"
        class={themeButtonClass}
      >
        <Moon size={iconSize} class="shrink-0" aria-hidden="true" />
        <span>{settings.themeDark}</span>
      </button>
      <button
        data-theme-button="system"
        aria-label={settings.themeSystem}
        aria-pressed="false"
        class={themeButtonClass}
      >
        <Monitor size={iconSize} class="shrink-0" aria-hidden="true" />
        <span>{settings.themeSystem}</span>
      </button>
    </div>
  </div>

  <div
    class="h-px bg-light-surface/40 dark:bg-dark-surface/40"
    aria-hidden="true"
  >
  </div>

  <div class="flex flex-col gap-1.5">
    <span class={labelClass}>{settings.colorScheme}</span>
    <div class:list={["grid gap-0.5", schemeCols]}>
      {
        colorSchemes.map((scheme) => (
          <button
            data-scheme-button={scheme.id}
            aria-label={scheme.label}
            aria-pressed="false"
            class={schemeButtonClass}
          >
            <span
              class:list={["rounded-full shrink-0", dotSize]}
              style={`background-color: ${scheme.selectorColor}`}
              aria-hidden="true"
            />
            <span class="truncate">{scheme.label}</span>
          </button>
        ))
      }
    </div>
  </div>
</div>
