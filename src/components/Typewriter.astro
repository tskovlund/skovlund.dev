---
/**
 * Typewriter — types, deletes, and retypes strings with a blinking cursor.
 *
 * Supports two ordering modes:
 *   - "cycle": ordered rotation through the texts array
 *   - "shuffle": random order, never the same text twice in a row
 *
 * Supports two color modes:
 *   - "random-gradient": generates 3-color gradients from --palette-* CSS vars
 *   - "indexed": uses pre-defined --greeting-color-N / --greeting-grad-N pairs
 *     and also sets the wrapper's text color (for cursor color matching)
 *
 * Supports two deletion modes:
 *   - "character": deletes one character at a time
 *   - "word": deletes one word at a time (back to previous space or start)
 *
 * Config is passed via a data attribute and initialized by a bundled script
 * that listens for astro:page-load — this avoids the re-execution issues
 * that is:inline scripts have with View Transitions.
 */

interface Props {
  id: string;
  texts: string[];
  mode: "cycle" | "shuffle";
  colorCount: number;
  colorMode?: "random-gradient" | "indexed";
  deleteMode?: "character" | "word";
  startFilled?: boolean;
  gradientClass?: string;
  typeSpeedMs?: number;
  deleteSpeedMs?: number;
  pauseBeforeDeleteMs?: number;
  pauseAfterDeleteMs?: number;
}

const {
  id,
  texts,
  mode,
  colorCount,
  colorMode = "random-gradient",
  deleteMode = "character",
  startFilled = false,
  gradientClass = "typewriter-gradient",
  typeSpeedMs = 100,
  deleteSpeedMs = 60,
  pauseBeforeDeleteMs = 2500,
  pauseAfterDeleteMs = 150,
} = Astro.props;

const config = JSON.stringify({
  texts,
  mode,
  colorCount,
  colorMode,
  deleteMode,
  startFilled,
  typeSpeedMs,
  deleteSpeedMs,
  pauseBeforeDeleteMs,
  pauseAfterDeleteMs,
});

const initialText = startFilled ? texts[0] : "";

// For indexed color mode, set initial inline styles so the first color
// is correct before JS runs (prevents a flash of default text color).
const initialWrapperStyle =
  colorMode === "indexed" ? `color: var(--greeting-color-0)` : undefined;
const initialTextStyle =
  colorMode === "indexed"
    ? `background-image: var(--greeting-grad-0)`
    : undefined;
---

<span id={`${id}-wrapper`} class="font-mono" style={initialWrapperStyle}>
  <span
    id={id}
    class={gradientClass}
    data-typewriter={config}
    style={initialTextStyle}>{initialText}</span
  ><span id={`${id}-cursor`} class="cursor-blink"></span>
</span>

<script>
  interface TypewriterConfig {
    texts: string[];
    mode: "cycle" | "shuffle";
    colorCount: number;
    colorMode: "random-gradient" | "indexed";
    deleteMode: "character" | "word";
    startFilled: boolean;
    typeSpeedMs: number;
    deleteSpeedMs: number;
    pauseBeforeDeleteMs: number;
    pauseAfterDeleteMs: number;
  }

  interface TypewriterElement extends HTMLElement {
    _typewriterActive?: boolean;
  }

  const GRADIENT_COLOR_COUNT = 3;

  function randomGradient(colorCount: number): string {
    const indices: number[] = [];
    while (indices.length < GRADIENT_COLOR_COUNT) {
      const candidate = Math.floor(Math.random() * colorCount);
      if (!indices.includes(candidate)) indices.push(candidate);
    }
    return (
      "linear-gradient(135deg, " +
      indices
        .map((colorIndex: number) => `var(--palette-${colorIndex})`)
        .join(", ") +
      ")"
    );
  }

  function applyColor(
    config: TypewriterConfig,
    textElement: HTMLElement,
    wrapperElement: HTMLElement,
    colorIndex: number,
  ): void {
    if (config.colorMode === "indexed") {
      wrapperElement.style.color = `var(--greeting-color-${colorIndex})`;
      textElement.style.backgroundImage = `var(--greeting-grad-${colorIndex})`;
    } else {
      textElement.style.backgroundImage = randomGradient(config.colorCount);
    }
  }

  function pickNextColorIndex(
    currentColorIndex: number,
    colorCount: number,
  ): number {
    let nextColorIndex: number;
    do {
      nextColorIndex = Math.floor(Math.random() * colorCount);
    } while (nextColorIndex === currentColorIndex);
    return nextColorIndex;
  }

  /** Find the character index of the previous word boundary (space or 0). */
  function previousWordBoundary(text: string, position: number): number {
    let index = position;
    // Remove the word's characters
    while (index > 0 && text[index - 1] !== " ") {
      index--;
    }
    // Also remove spaces before the word (so no trailing space remains)
    while (index > 0 && text[index - 1] === " ") {
      index--;
    }
    return index;
  }

  function initializeTypewriter(textElement: TypewriterElement): void {
    if (textElement._typewriterActive) return;
    textElement._typewriterActive = true;

    const configAttribute = textElement.dataset.typewriter;
    if (!configAttribute) return;
    const config: TypewriterConfig = JSON.parse(configAttribute);
    const maybeCursorElement =
      textElement.nextElementSibling as HTMLElement | null;
    if (!maybeCursorElement) return;
    const cursorElement: HTMLElement = maybeCursorElement;
    const wrapperElement = textElement.parentElement as HTMLElement;

    // Skip animation for users who prefer reduced motion
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      textElement.textContent = config.texts[0];
      applyColor(config, textElement, wrapperElement, 0);
      cursorElement.classList.remove("cursor-blink");
      return;
    }

    let currentIndex = 0;
    let characterIndex = config.startFilled ? config.texts[0].length : 0;
    let isDeleting = false;
    let activeColorIndex = 0;

    function pickNextIndex(): number {
      if (config.mode === "cycle") {
        return (currentIndex + 1) % config.texts.length;
      }
      // Shuffle: random but never same twice in a row
      if (config.texts.length <= 1) return 0;
      let nextIndex: number;
      do {
        nextIndex = Math.floor(Math.random() * config.texts.length);
      } while (nextIndex === currentIndex);
      return nextIndex;
    }

    function tick(): void {
      const currentText = config.texts[currentIndex];
      cursorElement.classList.add("cursor-typing");

      if (isDeleting) {
        if (config.deleteMode === "word") {
          characterIndex = previousWordBoundary(currentText, characterIndex);
        } else {
          characterIndex--;
        }
        textElement.textContent = currentText.substring(0, characterIndex);

        if (characterIndex === 0) {
          isDeleting = false;
          currentIndex = pickNextIndex();
          activeColorIndex = pickNextColorIndex(
            activeColorIndex,
            config.colorCount,
          );
          applyColor(config, textElement, wrapperElement, activeColorIndex);
          setTimeout(tick, config.pauseAfterDeleteMs);
        } else {
          setTimeout(tick, config.deleteSpeedMs);
        }
      } else {
        characterIndex++;
        textElement.textContent = config.texts[currentIndex].substring(
          0,
          characterIndex,
        );

        if (characterIndex === config.texts[currentIndex].length) {
          cursorElement.classList.remove("cursor-typing");
          setTimeout((): void => {
            isDeleting = true;
            tick();
          }, config.pauseBeforeDeleteMs);
        } else {
          setTimeout(tick, config.typeSpeedMs);
        }
      }
    }

    // For shuffle mode, pick a random first message
    if (config.mode === "shuffle" && !config.startFilled) {
      currentIndex = Math.floor(Math.random() * config.texts.length);
    }

    // Apply initial color
    applyColor(config, textElement, wrapperElement, activeColorIndex);

    if (config.startFilled) {
      // Start with text visible, pause, then begin deleting
      setTimeout((): void => {
        isDeleting = true;
        tick();
      }, config.pauseBeforeDeleteMs);
    } else {
      tick();
    }
  }

  function initializeAllTypewriters(): void {
    document
      .querySelectorAll<TypewriterElement>("[data-typewriter]")
      .forEach((element: TypewriterElement) => initializeTypewriter(element));
  }

  // astro:page-load fires on both initial load and after each View Transition.
  // Persisted elements retain their _typewriterActive flag, preventing re-init.
  document.addEventListener("astro:page-load", initializeAllTypewriters);
</script>
