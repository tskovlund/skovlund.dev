---
import type { GetStaticPathsResult } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";

import BackToPrev from "@components/BackToPrev.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Lightbox from "@components/Lightbox.astro";
import { backLinks } from "@i18n/en";
import PageLayout from "@layouts/PageLayout.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort(
      (first, second) => second.data.date.valueOf() - first.data.date.valueOf(),
    );
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <Container>
    <div class="animate">
      <BackToPrev href="/blog"> {backLinks.blog} </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body)}
        </div>
      </div>
      <h1
        class="animate text-2xl font-mono font-semibold text-light-fg dark:text-dark-fg"
      >
        {post.data.title}
      </h1>
    </div>
    <article class="animate">
      <Content />
    </article>
    <Lightbox />
  </Container>
</PageLayout>
