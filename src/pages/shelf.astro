---
import Container from "@components/Container.astro";
import RichText from "@components/RichText.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ShelfList from "@components/ShelfList.astro";
import { SHELF } from "@consts";
import { shelf } from "@i18n/en";
import PageLayout from "@layouts/PageLayout.astro";
import type { ThemeColor } from "@types";

const SECTION_COLORS: ThemeColor[] = [
  "accent",
  "warm",
  "cyan",
  "green",
  "red",
  "orange",
  "yellow",
];

const sections = [
  { key: "reading", items: shelf.reading },
  { key: "music", items: shelf.music },
  { key: "film", items: shelf.film },
  { key: "tv", items: shelf.tv },
  { key: "videoGames", items: shelf.videoGames },
  { key: "boardGames", items: shelf.boardGames },
  { key: "creators", items: shelf.creators },
  { key: "competitiveProgramming", items: shelf.competitiveProgramming },
  { key: "tools", items: shelf.tools },
  { key: "everythingElse", items: shelf.everythingElse },
] as const;

const sectionKeys = sections.map(({ key }) => key);
---

<PageLayout title={SHELF.TITLE} description={SHELF.DESCRIPTION}>
  <Container>
    <h1 class="sr-only">{SHELF.TITLE}</h1>
    <p
      class="animate text-sm text-light-fg-muted dark:text-dark-fg-muted text-center mb-6"
    >
      <RichText segments={shelf.intro} />
    </p>

    <nav
      class="animate flex flex-wrap justify-center gap-x-1 gap-y-1 mb-10 text-sm font-mono"
    >
      {
        sectionKeys.map((key, index) => (
          <>
            <a
              href={`#${key}`}
              class="text-light-fg-muted dark:text-dark-fg-muted hover:text-light-accent dark:hover:text-dark-accent transition-colors"
            >
              {shelf.sections[key]}
            </a>
            {index < sectionKeys.length - 1 && (
              <span class="text-light-fg-muted/30 dark:text-dark-fg-muted/30">
                /
              </span>
            )}
          </>
        ))
      }
    </nav>

    <div class="space-y-10">
      {
        sections.map(({ key, items }, index) => (
          <section id={key} class="animate space-y-4 scroll-mt-32">
            <SectionHeading
              color={SECTION_COLORS[index % SECTION_COLORS.length]}
            >
              {shelf.sections[key]}
            </SectionHeading>
            <ShelfList items={[...items]} />
          </section>
        ))
      }
    </div>
  </Container>
</PageLayout>
